# Conexão com o Banco de Dados (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/borapassageiro"

# JWT Secret para Sessões do Admin
JWT_SECRET="sua-chave-super-secreta-aqui"

# Configuração de Notificações de Motoristas (Telegram)
# Crie um bot no BotFather e pegue o token
TELEGRAM_BOT_TOKEN="123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ"
# Pegue seu ID usando @userinfobot ou crie um grupo
TELEGRAM_CHAT_ID="-1000000000000"

# Ou use um Webhook genérico (ex: n8n, make)
WEBHOOK_URL="https://n8n.seudominio.com/webhook/123"

# Rastreamento e Analytics
NEXT_PUBLIC_FB_PIXEL_ID="SEU_ID_AQUI"
NEXT_PUBLIC_GA_ID="G-SEUIDAQUI"
