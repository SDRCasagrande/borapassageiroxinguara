// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt hash
  nome      String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Motorista {
  id          String   @id @default(uuid())
  nome        String
  telefone    String?
  fotoUrl     String?
  ativo       Boolean  @default(true)
  status      String   @default("ativo") // ativo, alerta
  pontos      Int      @default(0)
  corridasMes Int      @default(0)
  corridas    Corrida[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Corrida {
  id            String   @id @default(uuid())
  idExterna     String?  // ID opcional da corrida no sistema externo
  motoristaId   String
  motorista     Motorista @relation(fields: [motoristaId], references: [id], onDelete: Cascade)
  data          DateTime @default(now())
  horaCorrida   DateTime? // Hora real da corrida (opcional)
}

model TrackingLink {
  id          String   @id @default(uuid())
  slug        String   @unique
  destino     String
  cliques     Click[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Click {
  id             String   @id @default(uuid())
  trackingLinkId String
  link           TrackingLink @relation(fields: [trackingLinkId], references: [id])
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime @default(now())
}

model MotoristaLead {
  id            String   @id @default(uuid())
  nome          String
  telefone      String
  cidade        String?
  veiculo       String?
  categoriaCnh  String?  // A, B, AB, C, D, E
  status        String   @default("PENDENTE") // PENDENTE, APROVADO, REJEITADO
  createdAt     DateTime @default(now())
}

model StatusApp {
  id        String   @id @default("1")
  ativo     Boolean  @default(true)
  mensagem  String?
  updatedAt DateTime @updatedAt
}

model FechamentoMes {
  id        String   @id @default(uuid())
  nome      String   // ex: "Junho 2026"
  dados     Json     // Snapshot do ranking (array de motoristas e corridas)
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(uuid())
  pagePath  String
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
}
